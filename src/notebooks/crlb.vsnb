    },
    {
     "items": [
      {
       "data": "<div class=\"wexpr\"><wgraph class=\"resizable\" style=\"width:187.8px;height:24.0px;\" aspect-ratio=\"0.127796\" tabIndex=\"-1\"><img src=\"data:image/png;base64,\" /></wgraph></div>",
